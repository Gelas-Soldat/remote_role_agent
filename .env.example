# Optional Adzuna source
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional USAJOBS source
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=your_email@example.com
USER_EMAIL=your_email@example.com

# Optional AI review button
